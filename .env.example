# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fax_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (e.g., S3, MinIO)
STORAGE_BUCKET=fax-documents
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key

# API Keys
OPENAI_API_KEY=your_openai_key  # For VLM if needed

# Multi-tenant
TENANT_ID=default

# OCR/VLM Config
OCR_MODEL_PATH=models/paddleocr
VLM_MODEL_PATH=models/donut

# Security
SECRET_KEY=your_secret_key_here
HIPAA_COMPLIANCE_MODE=true